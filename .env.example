# Optional: enables LLM-augmented answer generation.
# Without this, TrustLoop runs in fully deterministic offline mode
# using TF-IDF retrieval and template composition.
#
# Choose one provider:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Or use Groq for fast inference:
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
